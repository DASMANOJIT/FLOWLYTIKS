# Backend (Render backend service)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
JWT_SECRET=replace-with-a-strong-secret
# Gmail SMTP credentials
EMAIL_USER=you@gmail.com
EMAIL_PASS=lpzjkjk... (app password)
# Optional: override sender address
EMAIL_FROM="Subho's Institute <you@gmail.com>"
# Optional backend settings
PORT=5000
CORS_ORIGIN=http://localhost:3001
REMINDER_CRON=0 9 * * *
REMINDER_TIMEZONE=Asia/Kolkata

# Frontend (Render frontend service / Next.js server)
# Used by Next.js rewrites to proxy /api/* -> backend /api/*
# Production must point to the deployed backend service, not localhost.
BACKEND_URL=https://your-backend-service.onrender.com
