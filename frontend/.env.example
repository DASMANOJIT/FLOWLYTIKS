# Browser-visible backend API base URL.
# Local development can use http://localhost:5000, or leave this empty if your
# Next.js dev proxy/rewrites handle /api locally.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional server-only rewrite fallback for Vercel/Next.js.
# Production should point to the deployed Render backend service.
BACKEND_URL=https://your-backend-service.onrender.com

# Optional debug flags (keep off in production)
NEXT_PUBLIC_RENDER_DEBUG=0
NEXT_PUBLIC_DEBUG_SIGNUP=0
