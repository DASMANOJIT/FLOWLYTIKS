generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                       Int                     @id @default(autoincrement())
  name                     String?
  email                    String                  @unique
  password                 String
  cashfreeVendorId         String?                 @unique
  cashfreeSettlementStatus TeacherSettlementStatus @default(NOT_CONFIGURED)
  createdAt                DateTime                @default(now())
  payments                 Payment[]               @relation("AdminPayments")
  gatewayOrders            PaymentGatewayOrder[]   @relation("AdminGatewayOrders")
}

model Student {
  id                 Int                   @id @default(autoincrement())
  name               String
  phone              String                @unique
  email              String?               @unique
  password           String
  school             String
  class              String
  joinDate           DateTime              @default(now())
  monthlyFee         Int                   @default(600)
  isVerified         Boolean               @default(false)
  isTwoFactorEnabled Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  payments           Payment[]
  gatewayOrders      PaymentGatewayOrder[]

  @@index([class])
  @@index([school])
  @@index([joinDate])
}

model EmailOtp {
  id         String   @id @default(cuid())
  email      String
  purpose    String   @default("login")
  otpHash    String
  attempts   Int      @default(0)
  expiresAt  DateTime
  lockedUntil DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([email, purpose], name: "EmailOtp_email_purpose_key")
}

model AuthRateLimitEvent {
  id        String   @id @default(cuid())
  namespace String
  key       String
  createdAt DateTime @default(now())

  @@index([namespace, key, createdAt])
  @@index([createdAt])
}

model UserSession {
  id        String   @id
  role      String
  userId    Int
  expiresAt DateTime
  revokedAt DateTime?
  closingRequestedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role, userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([closingRequestedAt])
}

model Payment {
  id                   Int                   @id @default(autoincrement())
  month                String
  academicYear         Int
  amount               Int
  currency             String                @default("INR")
  status               String                @default("created")
  paymentProvider      PaymentProvider?
  paidAt               DateTime?
  isLatePayment        Boolean               @default(false)
  phonepeTransactionId String?
  phonepePaymentId     String?
  studentId            Int
  teacherAdminId       Int?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  student              Student               @relation(fields: [studentId], references: [id])
  teacherAdmin         Admin?                @relation("AdminPayments", fields: [teacherAdminId], references: [id])
  gatewayOrders        PaymentGatewayOrder[]

  @@unique([studentId, month, academicYear])
  @@index([studentId, academicYear, createdAt])
  @@index([academicYear, month, status])
  @@index([status, createdAt])
  @@index([phonepeTransactionId])
  @@index([phonepePaymentId])
  @@index([teacherAdminId])
}

model PaymentGatewayOrder {
  id                  String               @id @default(cuid())
  provider            PaymentProvider      @default(CASHFREE)
  status              GatewayPaymentStatus @default(PENDING)
  paymentId           Int
  studentId           Int
  teacherAdminId      Int?
  amount              Int
  currency            String               @default("INR")
  month               String
  academicYear        Int
  cashfreeOrderId     String?              @unique
  cashfreeCfOrderId   String?              @unique
  paymentSessionId    String?
  paymentMethodHint   String?
  paymentMethod       String?
  returnUrl           String?
  notifyUrl           String?
  orderStatus         String?
  orderExpiryTime     DateTime?
  gatewayReference    String?
  metadata            Json?
  rawCreateResponse   Json?
  paidAt              DateTime?
  verifiedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  payment             Payment              @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  student             Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherAdmin        Admin?               @relation("AdminGatewayOrders", fields: [teacherAdminId], references: [id], onDelete: SetNull)
  attempts            PaymentAttempt[]
  webhookEvents       PaymentWebhookEvent[]

  @@index([paymentId, status])
  @@index([studentId, month, academicYear])
  @@index([teacherAdminId])
}

model PaymentAttempt {
  id                     String               @id @default(cuid())
  gatewayOrderId         String
  provider               PaymentProvider      @default(CASHFREE)
  status                 GatewayPaymentStatus @default(PENDING)
  cashfreeOrderId        String?
  cfPaymentId            String?              @unique
  paymentGroup           String?
  paymentMethod          String?
  paymentMessage         String?
  bankReference          String?
  gatewayPaymentId       String?
  gatewayOrderReference  String?
  paymentAmount          Float?
  paymentTime            DateTime?
  rawPayload             Json?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  gatewayOrder           PaymentGatewayOrder  @relation(fields: [gatewayOrderId], references: [id], onDelete: Cascade)

  @@index([gatewayOrderId, createdAt])
  @@index([cashfreeOrderId])
}

model PaymentWebhookEvent {
  id              String               @id @default(cuid())
  provider        PaymentProvider      @default(CASHFREE)
  gatewayOrderId  String?
  dedupeKey       String               @unique
  eventType       String
  cashfreeOrderId String?
  cfPaymentId     String?
  signature       String?
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime             @default(now())
  gatewayOrder    PaymentGatewayOrder? @relation(fields: [gatewayOrderId], references: [id], onDelete: SetNull)

  @@index([cashfreeOrderId])
  @@index([cfPaymentId])
}

model BackgroundJob {
  id                String              @id @default(cuid())
  type              BackgroundJobType
  status            BackgroundJobStatus @default(PENDING)
  source            String
  requestedByRole   String?
  requestedByUserId Int?
  dedupeKey         String?             @unique
  payload           Json?
  totalItems        Int                 @default(0)
  processedItems    Int                 @default(0)
  succeededItems    Int                 @default(0)
  failedItems       Int                 @default(0)
  errorMessage      String?
  result            Json?
  startedAt         DateTime?
  completedAt       DateTime?
  lastHeartbeatAt   DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([type, status])
  @@index([requestedByRole, requestedByUserId])
}


model AppSettings {
  id         Int @id @default(1)
  monthlyFee Int
}

enum PaymentProvider {
  CASH
  PHONEPE
  CASHFREE
}

enum GatewayPaymentStatus {
  PENDING
  INITIATED
  PAID
  FAILED
  CANCELLED
  EXPIRED
}

enum TeacherSettlementStatus {
  NOT_CONFIGURED
  PENDING
  ACTIVE
  DISABLED
}

enum BackgroundJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum BackgroundJobType {
  DAILY_FEE_REMINDER
  ANNUAL_STUDENT_PROMOTION
  ASSISTANT_BULK_REMINDER
  ASSISTANT_BULK_MARK_PAID
  PAYMENT_RECONCILIATION
  REPORT_GENERATION
}
