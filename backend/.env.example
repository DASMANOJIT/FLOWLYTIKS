DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
JWT_SECRET=replace-with-a-32-plus-character-secret-value

# Email delivery (Resend HTTP API)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM="Subho's Institute <noreply@yourdomain.com>"

PORT=5000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://flowlytiks-frontend.onrender.com
CORS_ORIGIN=http://localhost:3001
# Keep this at 1 for a single web instance, or set web=0 and run `npm run jobs` in a dedicated worker.
RUN_SCHEDULED_JOBS=1
REMINDER_CRON=0 9 * * *
REMINDER_TIMEZONE=Asia/Kolkata
