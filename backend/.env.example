DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
JWT_SECRET=replace-with-a-32-plus-character-secret-value

# Email delivery (Resend HTTP API)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM="Subho's Institute <noreply@yourdomain.com>"

# Cashfree Payment Gateway
CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_ENVIRONMENT=sandbox
CASHFREE_RETURN_URL=http://localhost:3001/payment-success
# Optional override. If omitted, webhook signature verification uses CASHFREE_CLIENT_SECRET.
CASHFREE_WEBHOOK_SECRET=

PORT=5000
BACKEND_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://flowlytiks-frontend.onrender.com
CORS_ORIGIN=http://localhost:3001
# Web API no longer runs schedulers. Run `npm run jobs` in a dedicated worker process and
# use RUN_SCHEDULED_JOBS=0 there only if you want the worker to skip cron registration.
RUN_SCHEDULED_JOBS=1
REMINDER_CRON=0 9 * * *
REMINDER_TIMEZONE=Asia/Kolkata
BACKGROUND_JOB_POLL_INTERVAL_MS=15000
BACKGROUND_JOB_BATCH_SIZE=25
BACKGROUND_JOB_STALE_MINUTES=15
