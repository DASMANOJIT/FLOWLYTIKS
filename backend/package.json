{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dedupe:phones": "node scripts/dedupeStudentPhones.js",
    "postinstall": "prisma generate",
    "validate:env": "node -e \"Promise.all([import('./config/loadEnv.js'), import('./config/env.js')]).then(([, env]) => { env.validateEnv(); console.log('ENV OK: true'); }).catch((e) => { console.error(e?.message || e); process.exit(1); })\""
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "prisma": "^6.19.0",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
